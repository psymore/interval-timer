{
  "name": "interval-timer",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "clean": "rimraf dist",
    "build": "npm run clean && electron-builder",
    "dist": "npm run clean && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.psymore.intervaltimer",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signExecutable": false
    },
    "mac": null,
    "files": [
      "**/*",
      "!spotify-credentials.example.json",
      "!docs/**",
      "!.claude/**",
      "!.superpowers/**",
      "!markdown/**",
      "!production-review/**",
      "!README.md",
      "!CLAUDE.md",
      "!*.md"
    ]
  },
  "overrides": {
    "@noble/hashes": "1.8.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "electron": "^41.10.1",
    "electron-builder": "^26.15.6",
    "knip": "^5.88.1",
    "madge": "^8.0.0",
    "rimraf": "^5.0.5"
  },
  "dependencies": {
    "electron-store": "^11.0.2"
  }
}
